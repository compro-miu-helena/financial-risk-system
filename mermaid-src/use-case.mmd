        UC4((Generate Risk Report))
        UC5((Download or Receive Risk Report))
        UC6((Maintain Risk Parameters))
        UC7((View Audit Trail))
        UC8((Send Monitoring Alert))
    end

    BU --> UC1
    BU --> UC5
    BU --> UC7
    AU --> UC1
    AU --> UC6
    TDS --> UC2
    RDS --> UC3
    IDP --> UC1
    UC4 --> UC2
    UC4 --> UC3
    UC4 --> UC8
    UC8 --> CMS
